# .env としてコピーして使う。シークレット(APIキー等)は .env.example 側には書かない。

# --- 生成LLM (vLLM, OpenAI 互換) ---
# Port 8000 = vllm-gemma4 (Gemma 4 26B-A4B FP8)。
# --served-model-name 未指定で起動しているので、HF model ID がそのまま served name になる。
LLM_PROVIDER=vllm
VLLM_ENDPOINT=http://localhost:8000/v1
VLLM_MODEL=google/gemma-4-26B-A4B-it
VLLM_API_KEY=dummy
VLLM_TIMEOUT=300

# --- 埋め込み (vLLM, OpenAI 互換) ---
# Port 8003 = vllm-embed-ruri (日本語特化 768次元)。
# 代替: Port 8002 (vllm-embed-bge) を使う場合は ENDPOINT と MODEL を入れ替える。
EMBEDDING_PROVIDER=vllm
VLLM_EMBEDDING_ENDPOINT=http://localhost:8003/v1
VLLM_EMBEDDING_MODEL=cl-nagoya/ruri-v3-310m

# --- 判定LLM 選択A: Azure OpenAI ---
# 実値は .env 側に入れる (ここには書かない)。
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_CHAT_DEPLOYMENT_NAME=gpt-4.1-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME=text-embedding-3-small

# --- 判定LLM 選択B: Anthropic Claude ---
# ANTHROPIC_API_KEY=

# --- PDF 抽出: Azure Document Intelligence (任意) ---
# 未設定なら chunker は pypdf にフォールバックする。
AZURE_DI_ENDPOINT=
AZURE_DI_API_KEY=
AZURE_DI_MODEL=prebuilt-layout

# --- 任意: ローカル Vision/OCR 系 (rageval からは現状未参照、将来用に予約) ---
# Port 8007 = paddlex-layout (レイアウト解析サービス)
# PADDLEX_LAYOUT_ENDPOINT=http://localhost:8007
# Port 8008 = vllm-paddleocr-vl (文書OCR/レイアウト特化 ~0.9B VLM)。--served-model-name 未指定。
# PADDLEOCR_VL_ENDPOINT=http://localhost:8008/v1
# PADDLEOCR_VL_MODEL=PaddlePaddle/PaddleOCR-VL
